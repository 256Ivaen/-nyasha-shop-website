<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Route product slug URLs to SEO meta proxy (bots get OG HTML, users get shell)
  RewriteRule ^product/([^/]+)/?$ meta-proxy.php?type=product&slug=$1 [L,QSA]

  # Redirect all other requests to index.html except for existing files and directories
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ /index.html [L]
</IfModule>
